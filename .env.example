# Copy this file to .env and fill in real values. Never commit .env itself.

# Database — get a free Postgres instance from Supabase, Railway, or Neon
DATABASE_URL=postgresql://user:password@localhost:5432/stormsentinel

# Auth — generate a real random secret, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_THIS_TO_A_REAL_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# LLM — free tier, get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# CORS — your frontend's URL(s), comma-separated. Update for production.
CORS_ORIGINS=http://localhost:3000
